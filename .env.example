# ─────────────────────────────────────────────────────────────────────────────
# Lewis Wealth Intelligence — example environment.
# Copy to .env (gitignored). NEVER commit real secrets. All values validated at
# boot with zod (see CLAUDE.md §7 / docs/SECURITY.md §3). Use placeholders only.
# ─────────────────────────────────────────────────────────────────────────────

# Core
NODE_ENV=development

# Database (Postgres + TimescaleDB)
DATABASE_URL=postgresql://lwi:lwi@localhost:5432/lwi

# Redis (cache, rate limiting, queues)
REDIS_URL=redis://localhost:6379

# Auth (Auth.js v5) — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-strong-random-secret
AUTH_URL=http://localhost:3000

# AI — Anthropic Claude (SERVER-SIDE ONLY, never expose to the client)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
AI_MODEL_ID=claude-opus-4-8

# Market data provider (adapter) — SERVER-SIDE ONLY
MARKET_DATA_PROVIDER=polygon
MARKET_DATA_API_KEY=REPLACE_ME

# Brokerage aggregator (read-only, tokenized) — SERVER-SIDE ONLY
BROKERAGE_AGGREGATOR=snaptrade
BROKERAGE_CLIENT_ID=REPLACE_ME
BROKERAGE_CLIENT_SECRET=REPLACE_ME

# Object storage (statements/exports)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=lwi-local
S3_ACCESS_KEY_ID=REPLACE_ME
S3_SECRET_ACCESS_KEY=REPLACE_ME

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
