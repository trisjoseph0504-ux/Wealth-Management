# ─────────────────────────────────────────────────────────────────────────────
# @lwi/web environment. Copy to .env.local (gitignored). Backend B0.
# The app runs with NO database when DATA_SOURCE=mock (the default).
# ─────────────────────────────────────────────────────────────────────────────

# Data source per the mock→DB migration plan (BACKEND_ARCHITECTURE §8).
#   mock = in-memory mock data (default, no DB required)
#   db   = Drizzle/Postgres (requires DATABASE_URL)
DATA_SOURCE=mock

# Required only when DATA_SOURCE=db. Neon or any Postgres connection string.
# DATABASE_URL=postgres://user:password@host:5432/lwi

# ── Auth (Backend B1) ────────────────────────────────────────────────────────
# Auth is OFF by default (demo mode runs without login). Set to true WITH a
# database (DATA_SOURCE=db + DATABASE_URL) and provider keys to enable real auth.
AUTH_ENABLED=false
# AUTH_SECRET=generate-with: openssl rand -base64 32
# AUTH_URL=http://localhost:3000
# AUTH_RESEND_KEY=re_...                  # magic-link email (Resend)
# AUTH_EMAIL_FROM=login@lewiswealth.example
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ── Market data ──────────────────────────────────────────────────────────────
# MARKET_DATA_PROVIDER=finnhub           # "mock" (default) or "finnhub"
# FINNHUB_API_KEY=

# ── AI Market Commentary (Anthropic) ─────────────────────────────────────────
# When set, the dashboard commentary is generated live by Claude; when unset it
# falls back to the built-in rules-based generator. Pay-as-you-go (pennies/use).
# ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (default claude-opus-4-8). Cheaper options for this use:
#   claude-sonnet-4-6  ·  claude-haiku-4-5
# ANTHROPIC_MODEL=claude-opus-4-8

# ── Access gate ──────────────────────────────────────────────────────────────
# When set, the whole site is password-protected (set only in hosting env vars).
# SITE_PASSWORD=
